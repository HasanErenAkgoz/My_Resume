# ─────────────────────────────────────────────────────────────
# Environment variables (copy to .env, never commit real values)
# ─────────────────────────────────────────────────────────────

# SSR server port
PORT=4000

# Analytics (Umami). Leave blank to disable.
UMAMI_WEBSITE_ID=
UMAMI_SCRIPT_URL=

# --- AI Chat (.NET 8 + SignalR backend) — never exposed to the browser ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# AI_CHAT_RATE_LIMIT_PER_HOUR=10
# Dev CORS origins allowed to open the SignalR hub (comma-separated).
# CORS_ORIGINS=http://localhost:4000,http://localhost:4200,http://localhost:5080

# --- Optional: GitHub token to raise API rate limits (not required) ---
# GITHUB_TOKEN=
